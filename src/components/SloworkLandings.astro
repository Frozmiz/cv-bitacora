---
import type { CollectionEntry } from 'astro:content';

interface Props {
  landings: NonNullable<CollectionEntry<'projects'>['data']['landings']>;
}

const { landings } = Astro.props;
---

<section class="slowork-landings" aria-labelledby="slowork-landings-title">
  <header class="slowork-landings__header">
    <p class="slowork-landings__label">Ecosistema Slowork</p>
    <h3 id="slowork-landings-title" class="slowork-landings__title">Landings y aprendizajes</h3>
    <p class="slowork-landings__intro">
      Tres superficies de captación con stacks y restricciones distintas.
      Cada una resuelve un funnel sin duplicar backend ni acoplar el deploy al monolito.
    </p>
  </header>

  <ol class="slowork-landings__list" role="list">
    {landings.map((landing, index) => (
      <li class="slowork-landings__item">
        <article class="slowork-landings__card" aria-labelledby={`landing-${landing.id}-title`}>
          <header class="slowork-landings__card-header">
            <span class="slowork-landings__index" aria-hidden="true">
              {String(index + 1).padStart(2, '0')}
            </span>
            <div class="slowork-landings__card-heading">
              {landing.url ? (
                <h4 id={`landing-${landing.id}-title`} class="slowork-landings__card-title">
                  <a
                    href={landing.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="slowork-landings__card-link"
                  >
                    {landing.name}
                  </a>
                </h4>
              ) : (
                <h4 id={`landing-${landing.id}-title`} class="slowork-landings__card-title">
                  {landing.name}
                </h4>
              )}
            </div>
          </header>

          <p class="slowork-landings__purpose">{landing.purpose}</p>

          {landing.technologies && landing.technologies.length > 0 && (
            <ul class="slowork-landings__tech" aria-label={`Tecnologías de ${landing.name}`}>
              {landing.technologies.map((tech) => (
                <li><span class="pill">{tech}</span></li>
              ))}
            </ul>
          )}

          <div class="slowork-landings__learning">
            <span class="slowork-landings__learning-label">Aprendizaje clave</span>
            <p class="slowork-landings__learning-text">{landing.learning}</p>
          </div>
        </article>
      </li>
    ))}
  </ol>
</section>

<style>
  .slowork-landings {
    margin-top: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid #27272A;
  }

  .slowork-landings__header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    max-width: 72ch;
  }

  .slowork-landings__label {
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #14B8A6;
    margin: 0;
  }

  .slowork-landings__title {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    color: #EDEDED;
    margin: 0;
  }

  .slowork-landings__intro {
    font-size: 0.875rem;
    line-height: 1.65;
    color: #A1A1AA;
    margin: 0;
  }

  .slowork-landings__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .slowork-landings__list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .slowork-landings__item {
    display: flex;
    flex-direction: column;
  }

  .slowork-landings__card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    height: 100%;
    background-color: #0A0A0A;
    border: 1px solid #27272A;
    border-radius: 0.75rem;
    padding: 1.25rem;
    transition: border-color 200ms ease;
  }

  .slowork-landings__card:hover {
    border-color: #3F3F46;
  }

  .slowork-landings__card-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .slowork-landings__index {
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    color: #52525B;
    letter-spacing: 0.06em;
    flex-shrink: 0;
    padding-top: 0.2rem;
  }

  .slowork-landings__card-title {
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: #EDEDED;
    margin: 0;
    line-height: 1.35;
  }

  .slowork-landings__card-link {
    color: inherit;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .slowork-landings__card-link:hover {
    color: #14B8A6;
  }

  .slowork-landings__purpose {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: #A1A1AA;
    margin: 0;
    flex: 1;
  }

  .slowork-landings__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .slowork-landings__learning {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-top: 0.75rem;
    border-top: 1px solid #27272A;
    margin-top: auto;
  }

  .slowork-landings__learning-label {
    font-family: var(--font-mono, monospace);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #10B981;
  }

  .slowork-landings__learning-text {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: #EDEDED;
    margin: 0;
  }
</style>
