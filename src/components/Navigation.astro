---
const links = [
  {
    href: '#inicio',
    label: 'Inicio',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    href: '#sobre-mi',
    label: 'Sobre mí',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>`,
  },
  {
    href: '#proyectos',
    label: 'Proyectos',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
  },
  {
    href: '#bitacora',
    label: 'Bitácora',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
] as const;

const cvLink = {
  href: '/cv',
  label: 'CV en PDF',
  icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
} as const;
---

<!--
  ── SIDEBAR (visible md+, oculto en mobile) ──────────────────────────────
-->
<nav
  class="sidebar"
  aria-label="Navegación principal"
>
  <!-- Logo / marca -->
  <a
    href="#inicio"
    class="sidebar__logo"
    aria-label="Inicio"
  >
    <span class="sidebar__logo-dot" aria-hidden="true"></span>
  </a>

  <!-- Enlace de navegación -->
  <ul class="sidebar__links" role="list">
    {links.map(({ href, label, icon }) => (
      <li>
        <a
          href={href}
          class="nav-link"
          aria-label={label}
          data-nav-link
        >
          <span class="nav-link__icon" set:html={icon} />
          <span class="nav-link__tooltip">{label}</span>
        </a>
      </li>
    ))}
  </ul>

  <a
    href={cvLink.href}
    class="sidebar__cv nav-link"
    aria-label={cvLink.label}
  >
    <span class="nav-link__icon" set:html={cvLink.icon} />
    <span class="nav-link__tooltip">{cvLink.label}</span>
  </a>
</nav>

<!--
  ── BOTTOM BAR (visible solo mobile, oculta md+) ─────────────────────────
-->
<nav
  class="bottom-bar"
  aria-label="Navegación (móvil)"
>
  {links.map(({ href, label, icon }) => (
    <a
      href={href}
      class="bottom-bar__link"
      aria-label={label}
      data-nav-link
    >
      <span class="bottom-bar__icon" set:html={icon} />
      <span class="bottom-bar__label">{label}</span>
    </a>
  ))}
</nav>

<style>
  /* ── Variables locales ───────────────────────────────────────────────── */
  :root {
    --nav-bg:       #111111;
    --nav-border:   #27272A;
    --nav-accent:   #14B8A6;
    --nav-text-dim: #A1A1AA;
    --nav-w:        4rem;   /* 64px */
    --nav-h-mob:    3.5rem; /* 56px */
  }

  /* ── Sidebar ─────────────────────────────────────────────────────────── */
  .sidebar {
    display: none; /* oculto en mobile */
    position: fixed;
    top: 0;
    left: 0;
    width: var(--nav-w);
    height: 100dvh;
    background: var(--nav-bg);
    border-right: 1px solid var(--nav-border);
    flex-direction: column;
    align-items: center;
    padding: 1.25rem 0;
    gap: 0;
    z-index: 50;
  }

  @media (min-width: 768px) {
    .sidebar { display: flex; }
  }

  /* Logo dot */
  .sidebar__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding-bottom: 1.5rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--nav-border);
    color: var(--nav-text-dim);
    transition: color 200ms ease;
    text-decoration: none;
  }
  .sidebar__logo:hover { color: var(--nav-accent); }

  .sidebar__logo-dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--nav-accent);
  }

  .sidebar__links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    flex: 1;
  }

  .sidebar__cv {
    margin-top: auto;
    border-top: 1px solid var(--nav-border);
    padding-top: 0.5rem;
  }

  /* ── Enlace genérico (sidebar) ───────────────────────────────────────── */
  .nav-link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.875rem 0;
    color: var(--nav-text-dim);
    text-decoration: none;
    transition: color 200ms ease, background-color 200ms ease;
  }

  .nav-link:hover,
  .nav-link[aria-current="page"] {
    color: var(--nav-accent);
    background-color: #14b8a60d; /* acento al 5% */
  }

  .nav-link__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 0;
  }

  /* Tooltip flotante a la derecha del icono */
  .nav-link__tooltip {
    position: absolute;
    left: calc(var(--nav-w) + 0.5rem);
    white-space: nowrap;
    background: #1A1A1A;
    border: 1px solid var(--nav-border);
    border-radius: 4px;
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    font-family: var(--font-mono, monospace);
    color: var(--nav-text-dim);
    pointer-events: none;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 150ms ease, transform 150ms ease;
  }

  .nav-link:hover .nav-link__tooltip {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Bottom Bar ──────────────────────────────────────────────────────── */
  .bottom-bar {
    display: flex;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--nav-h-mob);
    background: var(--nav-bg);
    border-top: 1px solid var(--nav-border);
    align-items: center;
    justify-content: space-around;
    z-index: 50;
    padding: 0 0.5rem;
  }

  @media (min-width: 768px) {
    .bottom-bar { display: none; }
  }

  .bottom-bar__link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    flex: 1;
    padding: 0.5rem 0;
    min-height: 44px; /* área táctil mínima DESIGN §8 */
    color: var(--nav-text-dim);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .bottom-bar__link:hover,
  .bottom-bar__link[aria-current="page"] {
    color: var(--nav-accent);
  }

  .bottom-bar__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .bottom-bar__label {
    font-size: 0.6rem;
    font-family: var(--font-mono, monospace);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>

<script>
  /**
   * Marca el enlace activo según la sección visible usando IntersectionObserver.
   * Actualiza aria-current="page" en todos los [data-nav-link] que comparten href.
   */
  function initActiveNav() {
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');
    if (!links.length) return;

    const sectionIds = [...new Set([...links].map(l => l.getAttribute('href')?.slice(1)).filter(Boolean))] as string[];

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            links.forEach((link) => {
              const active = link.getAttribute('href') === `#${id}`;
              link.toggleAttribute('aria-current', active);
              if (active) link.setAttribute('aria-current', 'page');
              else link.removeAttribute('aria-current');
            });
          }
        }
      },
      { rootMargin: '-40% 0px -55% 0px', threshold: 0 },
    );

    sectionIds.forEach((id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }

  document.addEventListener('DOMContentLoaded', initActiveNav);
</script>
