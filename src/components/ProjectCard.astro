---
import type { CollectionEntry } from 'astro:content';
import ArticleWireframe from './ArticleWireframe.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  /**
   * Cuando es true, la tarjeta solicita al grid que ocupe 2 columnas.
   * El grid padre aplica la clase col-span mediante data attribute.
   */
  featured?: boolean;
  index?: number;
}

const CORNERS = ['tr', 'tl', 'br', 'bl'] as const;

const { project, featured = false, index = 0 } = Astro.props;
const corner = featured ? 'tr' : CORNERS[index % CORNERS.length];
const intensity = featured ? 'medium' : 'soft';
const crop = (index % 4) as 0 | 1 | 2 | 3;
const { title, status, description, problem, technologies, links } = project.data;

/** Indicador visual de estado: colores del DESIGN.md §2 Status/Logbook */
const STATUS_MAP = {
  'Completado':    { color: '#10B981', label: 'Completado' },
  'En Desarrollo': { color: '#F59E0B', label: 'En Desarrollo' },
  'Mantenimiento': { color: '#14B8A6', label: 'Mantenimiento' },
} satisfies Record<typeof status, { color: string; label: string }>;

const statusInfo = STATUS_MAP[status];
---

<article
  class="project-card"
  data-featured={featured ? 'true' : undefined}
  aria-label={`Proyecto: ${title}`}
>
  <ArticleWireframe corner={corner} intensity={intensity} crop={crop} />

  <!-- ── Cabecera ──────────────────────────────────────────────────────── -->
  <header class="project-card__header">
    <h3 class="project-card__title">{title}</h3>

    <span class="project-card__status" aria-label={`Estado: ${statusInfo.label}`}>
      <span
        class="project-card__status-dot"
        style={`background-color: ${statusInfo.color};`}
        aria-hidden="true"
      ></span>
      <span class="project-card__status-label">{statusInfo.label}</span>
    </span>
  </header>

  <!-- ── Cuerpo ────────────────────────────────────────────────────────── -->
  <div class="project-card__body">
    <p class="project-card__description">{description}</p>

    <div class="project-card__problem">
      <span class="project-card__problem-label">Problema</span>
      <p class="project-card__problem-text">{problem}</p>
    </div>
  </div>

  <!-- ── Footer ────────────────────────────────────────────────────────── -->
  <footer class="project-card__footer">
    <!-- Pills de tecnologías -->
    <ul class="project-card__tech" aria-label="Tecnologías">
      {technologies.map((tech) => (
        <li><span class="pill">{tech}</span></li>
      ))}
    </ul>

    <!-- Enlaces: solo se renderizan si existen -->
    {(links?.github || links?.demo) && (
      <div class="project-card__links">
        {links.github && (
          <a
            href={links.github}
            target="_blank"
            rel="noopener noreferrer"
            class="project-card__link"
            aria-label={`Ver código fuente de ${title} en GitHub`}
          >
            <!-- GitHub icon -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
            GitHub
          </a>
        )}
        {links.demo && (
          <a
            href={links.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="project-card__link"
            aria-label={`Ver demo de ${title}`}
          >
            <!-- External link icon -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
            Demo
          </a>
        )}
      </div>
    )}
  </footer>
</article>

<style>
  /* ── Tarjeta (DESIGN §4 Tarjetas de Proyecto) ───────────────────────── */
  .project-card {
    position: relative;
    overflow: hidden;
    background-color: #111111;          /* Surface 1 */
    border: 1px solid #27272A;          /* Zinc-800 */
    border-radius: 0.75rem;             /* 12px */
    padding: 1.5rem;                    /* 24px */
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 200ms ease;
    height: 100%;
  }

  .project-card:hover {
    border-color: #3F3F46;              /* Zinc-700: hover sutil */
  }

  /* Contenido por encima del wireframe interno */
  .project-card > :not(:global(.art-wire)) {
    position: relative;
    z-index: 1;
  }

  /* ── Cabecera ────────────────────────────────────────────────────────── */
  .project-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .project-card__title {
    font-size: 1.125rem;                /* 18px */
    font-weight: 600;
    letter-spacing: -0.025em;
    color: #EDEDED;
    margin: 0;
    line-height: 1.3;
  }

  .project-card__status {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .project-card__status-dot {
    display: block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .project-card__status-label {
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #A1A1AA;
    white-space: nowrap;
  }

  /* ── Cuerpo ──────────────────────────────────────────────────────────── */
  .project-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;                            /* empuja el footer hacia abajo */
  }

  .project-card__description {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: #EDEDED;
    margin: 0;
  }

  .project-card__problem {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .project-card__problem-label {
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #A1A1AA;
  }

  .project-card__problem-text {
    font-size: 0.875rem;
    line-height: 1.65;
    color: #A1A1AA;
    margin: 0;
  }

  /* ── Footer ──────────────────────────────────────────────────────────── */
  .project-card__footer {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding-top: 0.5rem;
    border-top: 1px solid #27272A;
    margin-top: auto;
  }

  .project-card__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .project-card__links {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .project-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #A1A1AA;
    text-decoration: none;
    transition: color 150ms ease;
    font-family: var(--font-mono, monospace);
  }

  .project-card__link:hover {
    color: #EDEDED;
  }

  .project-card__link svg {
    flex-shrink: 0;
  }
</style>
