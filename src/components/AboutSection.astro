---
import { cv } from "../config/site";
import RootsSection from "./RootsSection.astro";
import AiWorkflowSection from "./AiWorkflowSection.astro";
---

<section id="sobre-mi" class="about-section">
  <div class="about-section__content">
    <header class="about-section__header">
      <p class="about-section__label">Perfil</p>
      <h2 class="about-section__title">Sobre mí</h2>
    </header>

    <div class="about-section__body">
      <div class="about-section__bio">
        <p class="about-section__lead">
          Soy <strong>Frontend Developer&nbsp;/&nbsp;Product Engineer</strong> con varios
          años construyendo productos digitales: aplicaciones web en producción, MVPs
          y proyectos propios donde pruebo stack y enfoque.
        </p>
        <p class="about-section__text">
          Me especializo en arquitecturas de interfaces de alto rendimiento,
          diseño de sistemas escalables y la frontera entre ingeniería y producto.
          Este sitio es mi CV vivo: proyectos reales y una bitácora con los
          problemas que he resuelto en el camino.
        </p>
      </div>

      <RootsSection />

      <AiWorkflowSection />

      <div class="about-section__actions">
        <a href="/cv" class="about-section__cv-link"> Ver currículum en PDF </a>
        <a href={cv.file} download class="about-section__cv-download">
          Descargar
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding-top: var(--spacing-section, 6rem);
    padding-bottom: var(--spacing-section, 6rem);
  }

  .about-section__content {
    max-width: 100%;
  }

  .about-section__bio {
    max-width: 72ch;
  }

  .about-section__header {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-bottom: 2rem;
  }

  .about-section__label {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #14b8a6;
    margin: 0;
  }

  .about-section__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: #ededed;
    margin: 0;
  }

  .about-section__body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-section__lead {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #ededed;
    margin: 0;
  }

  .about-section__lead strong {
    font-weight: 500;
  }

  .about-section__text {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: #a1a1aa;
    margin: 0;
  }

  .about-section__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.5rem;
  }

  .about-section__cv-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.625rem 1.25rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    background-color: #ededed;
    color: #0a0a0a;
    text-decoration: none;
    transition: opacity 150ms ease;
  }

  .about-section__cv-link:hover {
    opacity: 0.88;
  }

  .about-section__cv-download {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.625rem 1.25rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: var(--font-mono, monospace);
    color: #a1a1aa;
    border: 1px solid #27272a;
    text-decoration: none;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      border-color 150ms ease;
  }

  .about-section__cv-download:hover {
    background-color: #1a1a1a;
    color: #ededed;
    border-color: #3f3f46;
  }
</style>
